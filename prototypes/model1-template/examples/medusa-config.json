{
  "name": "zerodast-medusa",
  "target": {
    "runtimeMode": "compose",
    "workingDirectory": ".",
    "port": 9000,
    "basePath": "",
    "apiSignalPathPrefix": "/admin/",
    "healthPath": "/health",
    "openApiPath": "/api/openapi.json",
    "compose": {
      "upCommand": "docker compose up -d",
      "downCommand": "docker compose down -v --remove-orphans",
      "networkName": "",
      "appHost": "medusa"
    }
  },
  "auth": {
    "adapter": "json-token-login",
    "loginPath": "/auth/user/emailpass",
    "contentType": "application/json",
    "emailField": "email",
    "passwordField": "password",
    "responseTokenField": "token",
    "headerName": "Authorization",
    "headerPrefix": "Bearer ",
    "user": {
      "email": "testuser@zerodast.local",
      "password": "Test123!"
    },
    "admin": {
      "email": "admin@zerodast.local",
      "password": "Admin123!"
    },
    "protectedRoute": {
      "path": "/store/customers/me",
      "expectedStatus": 200
    },
    "adminRoute": {
      "path": "/admin/products",
      "expectedStatus": 200
    }
  },
  "scan": {
    "zapVersion": "2.17.0",
    "helperImage": "node:20-alpine",
    "spiderPath": "/",
    "mode": {
      "pr": {
        "maxDurationMinutes": 5,
        "enableSpider": true,
        "spiderMinutes": 1,
        "spiderMaxDepth": 5,
        "spiderMaxChildren": 50,
        "passiveWaitMinutes": 2,
        "threadPerHost": 4,
        "defaultStrength": "medium",
        "defaultThreshold": "low"
      },
      "nightly": {
        "maxDurationMinutes": 15,
        "enableSpider": true,
        "spiderMinutes": 2,
        "spiderMaxDepth": 5,
        "spiderMaxChildren": 50,
        "passiveWaitMinutes": 2,
        "threadPerHost": 4,
        "defaultStrength": "medium",
        "defaultThreshold": "low"
      }
    },
    "requestSeeds": [
      "/admin/products",
      "/admin/orders",
      "/admin/customers",
      "/store/products",
      "/store/collections"
    ]
  },
  "reporting": {
    "successMode": "route_exercise",
    "minObservedApiRequestorUrls": 1,
    "minSeedObservationRatio": 0.5
  }
}
