{
  "name": "zerodast-nocodb",
  "target": {
    "runtimeMode": "compose",
    "workingDirectory": ".",
    "port": 8080,
    "basePath": "",
    "apiSignalPathPrefix": "/api/",
    "healthPath": "/api/v1/health",
    "openApiPath": "/api/v1/swagger.json",
    "compose": {
      "upCommand": "docker compose up -d",
      "downCommand": "docker compose down -v --remove-orphans",
      "networkName": "",
      "appHost": "nocodb"
    }
  },
  "auth": {
    "adapter": "json-token-login",
    "loginPath": "/api/v1/auth/user/signin",
    "contentType": "application/json",
    "emailField": "email",
    "passwordField": "password",
    "responseTokenField": "token",
    "headerName": "xc-auth",
    "headerPrefix": "",
    "user": {
      "email": "testuser@zerodast.local",
      "password": "Test123!"
    },
    "admin": {
      "email": "admin@zerodast.local",
      "password": "Admin123!"
    },
    "protectedRoute": {
      "path": "/api/v1/meta/tables",
      "expectedStatus": 200
    },
    "adminRoute": {
      "path": "/api/v1/users",
      "expectedStatus": 200
    }
  },
  "scan": {
    "zapVersion": "2.17.0",
    "helperImage": "node:20-alpine",
    "spiderPath": "/dashboard",
    "mode": {
      "pr": {
        "maxDurationMinutes": 5,
        "enableSpider": true,
        "spiderMinutes": 1,
        "spiderMaxDepth": 5,
        "spiderMaxChildren": 50,
        "passiveWaitMinutes": 2,
        "threadPerHost": 4,
        "defaultStrength": "medium",
        "defaultThreshold": "low"
      },
      "nightly": {
        "maxDurationMinutes": 15,
        "enableSpider": true,
        "spiderMinutes": 2,
        "spiderMaxDepth": 5,
        "spiderMaxChildren": 50,
        "passiveWaitMinutes": 2,
        "threadPerHost": 4,
        "defaultStrength": "medium",
        "defaultThreshold": "low"
      }
    },
    "requestSeeds": [
      "/api/v1/meta/tables",
      "/api/v1/users",
      "/api/v1/db/meta/projects"
    ]
  },
  "reporting": {
    "successMode": "route_exercise",
    "minObservedApiRequestorUrls": 1,
    "minSeedObservationRatio": 0.5
  }
}
