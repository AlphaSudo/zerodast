{
  "name": "zerodast-eventdebug-example",
  "target": {
    "runtimeMode": "compose",
    "workingDirectory": ".",
    "port": 9090,
    "basePath": "/api/v1",
    "apiSignalPathPrefix": "/api/v1/",
    "healthPath": "/api/v1/health/ready",
    "openApiPath": "/api/v1/openapi.json",
    "compose": {
      "upCommand": "podman-compose up -d postgres kafka app",
      "downCommand": "podman-compose down -v --remove-orphans",
      "networkName": "eventdebug-benchmark_default",
      "appHost": "eventlens-app"
    }
  },
  "scan": {
    "zapVersion": "2.17.0",
    "helperImage": "node:20-alpine",
    "mode": {
      "pr": {
        "maxDurationMinutes": 5,
        "enableSpider": true,
        "spiderMinutes": 1,
        "threadPerHost": 4
      },
      "nightly": {
        "maxDurationMinutes": 20,
        "enableSpider": true,
        "spiderMinutes": 2,
        "threadPerHost": 4
      }
    },
    "requestSeeds": [
      "/api/v1/events/recent?limit=10",
      "/api/v1/aggregates/search?q=ORD&limit=10",
      "/api/v1/aggregates/search?q=ACC&limit=10",
      "/api/v1/aggregates/ORD-001/timeline?limit=10",
      "/api/v1/aggregates/ACC-002/timeline?limit=10"
    ]
  },
  "reporting": {
    "requireApiSignal": true
  }
}
