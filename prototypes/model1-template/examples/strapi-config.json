{
  "name": "zerodast-strapi",
  "target": {
    "runtimeMode": "compose",
    "workingDirectory": ".",
    "port": 1337,
    "basePath": "",
    "apiSignalPathPrefix": "/api/",
    "healthPath": "/_health",
    "openApiPath": "/api/docs",
    "compose": {
      "upCommand": "docker compose up -d",
      "downCommand": "docker compose down -v --remove-orphans",
      "networkName": "",
      "appHost": "strapi"
    }
  },
  "auth": {
    "adapter": "json-token-login",
    "loginPath": "/api/auth/local",
    "contentType": "application/json",
    "emailField": "identifier",
    "passwordField": "password",
    "responseTokenField": "jwt",
    "headerName": "Authorization",
    "headerPrefix": "Bearer ",
    "user": {
      "email": "testuser@zerodast.local",
      "password": "Test123!"
    },
    "admin": {
      "email": "admin@zerodast.local",
      "password": "Admin123!"
    },
    "protectedRoute": {
      "path": "/api/users/me",
      "expectedStatus": 200
    },
    "adminRoute": {
      "path": "/api/users",
      "expectedStatus": 200
    }
  },
  "scan": {
    "zapVersion": "2.17.0",
    "helperImage": "node:20-alpine",
    "spiderPath": "/",
    "mode": {
      "pr": {
        "maxDurationMinutes": 5,
        "enableSpider": true,
        "spiderMinutes": 1,
        "spiderMaxDepth": 5,
        "spiderMaxChildren": 50,
        "passiveWaitMinutes": 2,
        "threadPerHost": 4,
        "defaultStrength": "medium",
        "defaultThreshold": "low"
      },
      "nightly": {
        "maxDurationMinutes": 15,
        "enableSpider": true,
        "spiderMinutes": 2,
        "spiderMaxDepth": 5,
        "spiderMaxChildren": 50,
        "passiveWaitMinutes": 2,
        "threadPerHost": 4,
        "defaultStrength": "medium",
        "defaultThreshold": "low"
      }
    },
    "requestSeeds": [
      "/api/users/me",
      "/api/content-types",
      "/api/upload/files"
    ]
  },
  "reporting": {
    "successMode": "route_exercise",
    "minObservedApiRequestorUrls": 1,
    "minSeedObservationRatio": 0.5
  }
}
