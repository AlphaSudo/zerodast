{
  "name": "zerodast-petclinic-example",
  "target": {
    "runtimeMode": "artifact",
    "buildCommand": "./mvnw -q -DskipTests package",
    "artifactPattern": "target/spring-petclinic-rest-*.jar",
    "workingDirectory": ".",
    "port": 9966,
    "basePath": "/petclinic",
    "apiSignalPathPrefix": "/petclinic/api/",
    "healthPath": "/petclinic/actuator/health",
    "openApiPath": "/petclinic/v3/api-docs",
    "appImage": "eclipse-temurin:17-jre-jammy",
    "compose": {
      "upCommand": "",
      "downCommand": "",
      "networkName": "",
      "appHost": ""
    }
  },
  "scan": {
    "zapVersion": "2.17.0",
    "helperImage": "node:20-alpine",
    "spiderPath": "/petclinic/swagger-ui/index.html",
    "mode": {
      "pr": {
        "maxDurationMinutes": 5,
        "enableSpider": true,
        "spiderMinutes": 1,
        "spiderMaxDepth": 5,
        "spiderMaxChildren": 50,
        "passiveWaitMinutes": 2,
        "threadPerHost": 4,
        "defaultStrength": "medium",
        "defaultThreshold": "low"
      },
      "nightly": {
        "maxDurationMinutes": 20,
        "enableSpider": true,
        "spiderMinutes": 2,
        "spiderMaxDepth": 5,
        "spiderMaxChildren": 50,
        "passiveWaitMinutes": 2,
        "threadPerHost": 4,
        "defaultStrength": "medium",
        "defaultThreshold": "low"
      }
    },
    "requestSeeds": [
      "/petclinic/",
      "/petclinic/api/owners",
      "/petclinic/api/owners/1",
      "/petclinic/api/owners/1/pets/1",
      "/petclinic/api/owners?lastName=Davis"
    ]
  },
  "reporting": {
    "successMode": "api_alerts",
    "minApiAlertUris": 1
  }
}
